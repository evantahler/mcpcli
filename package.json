{
  "name": "@evantahler/mcpcli",
  "version": "0.8.0",
  "description": "A command-line interface for MCP servers. curl for MCP.",
  "type": "module",
  "bin": {
    "mcpcli": "./src/cli.ts"
  },
  "files": [
    "src",
    ".claude",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "build": "bun build --compile --minify --sourcemap ./src/cli.ts --outfile dist/mcpcli"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/mcpcli.git"
  },
  "keywords": [
    "mcp",
    "cli",
    "model-context-protocol",
    "ai",
    "llm",
    "tools"
  ],
  "author": "Evan Tahler",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "ansis": "^4.2.0",
    "commander": "^14.0.3",
    "nanospinner": "^1.2.2",
    "picomatch": "^4.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.2",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
